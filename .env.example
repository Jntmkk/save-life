# Build / deployment tag used by docker-compose.yml
TAG=latest

# Frontend API URL. Set to your backend public URL when deploying.
# Example: VITE_API_URL=http://your-server-ip:3111
VITE_API_URL=https://api.fake-rest.refine.dev

# Auth service (backend-auth). In production behind nginx this is the site origin,
# e.g. VITE_AUTH_API_URL=https://your-domain.com (requests go to /api/auth/...).
VITE_AUTH_API_URL=http://localhost:8080

# MySQL (Aliyun RDS) used by backend-auth.
# Quote values containing $ or # so Compose doesn't mangle them.
DB_HOST=rm-bp10k2do8273syqapro.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=root
DB_PASSWORD='change-me'
# save_life_prod for the deployed stack, save_life_test for testing
DB_NAME=save_life_prod

# JWT signing secret for backend-auth (generate a long random string)
JWT_SECRET='change-me-to-a-long-random-string'
