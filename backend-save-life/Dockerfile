# iii project Dockerfile — generated by `iii project generate-docker`.
# Edit freely; re-running the generator will not overwrite this file.
FROM iiidev/iii:latest AS engine

ENV III_EXECUTION_CONTEXT=docker
ENV III_HOST_USER_ID=f91f3c4083a87aaaeacd1f3aba756178f01df8daa01c644dad1188892bfe45e7

WORKDIR /app
COPY config.yaml /app/config.yaml
COPY data /app/data
# iii.lock is engine-managed runtime state (worker registration); the engine
# creates it on first run if missing, so we don't COPY it from the host.
# (Doing so would also fail `docker build` for fresh projects that haven't
# generated one yet, and `iiidev/iii:latest` is distroless so `RUN touch`
# isn't an option.)

# Add 49135 here when enabling iii-worker-manager in config.yaml (Browser SDK / RBAC).
EXPOSE 49134 3111 3112 9464

# Pre-download the iii-console binary so `iii console` works in offline/server
# environments. Must match the engine version in iii.lock.
FROM alpine:3.19 AS console-downloader
ARG III_VERSION=0.20.0
ARG TARGETARCH=x86_64
RUN apk add --no-cache curl tar && \
    curl -fsSL -o /tmp/iii-console.tar.gz \
      "https://github.com/iii-hq/iii/releases/download/iii/v${III_VERSION}/iii-console-${TARGETARCH}-unknown-linux-musl.tar.gz" && \
    tar -xzf /tmp/iii-console.tar.gz -C /tmp iii-console && \
    chmod +x /tmp/iii-console

FROM engine
COPY --from=console-downloader /tmp/iii-console /app/iii-console
ENV PATH=/app:$PATH

ENTRYPOINT ["/app/iii"]
CMD ["--config", "/app/config.yaml"]
